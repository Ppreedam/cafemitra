DJANGO_SECRET_KEY=replace-with-production-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.repetigo.com,repetigo.com,www.repetigo.com
CORS_ALLOWED_ORIGINS=https://repetigo.com,https://www.repetigo.com
CSRF_TRUSTED_ORIGINS=https://repetigo.com,https://www.repetigo.com
FRONTEND_URL=https://repetigo.com

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USE_TLS=1
SMTP_TIMEOUT=15
SMTP_USER=support@repetigo.com
SMTP_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=support@repetigo.com
